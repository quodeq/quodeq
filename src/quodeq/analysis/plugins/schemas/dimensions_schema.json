{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plugin dimensions configuration",
  "type": "object",
  "required": ["applies"],
  "properties": {
    "_note": { "type": "string" },
    "applies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "weight"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "weight": { "type": "number", "minimum": 0 },
          "name": { "type": "string" },
          "iso_25010": { "type": "string" },
          "source": { "type": "string" },
          "type": { "type": "string" }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "excludes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}

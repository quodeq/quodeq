{
  "id": "maintainability",
  "name": "Maintainability",
  "description": "How effectively the codebase can be modified by people who did not write it. Modularity, reusability, analysability, modifiability, and testability keep changes safe, fast, and predictable as the system grows.",
  "sources": [
    "iso25010",
    "cisq"
  ],
  "principles": [
    {
      "name": "Modularity",
      "description": "Each part of the codebase has a focused responsibility and clean boundaries. Small modules, low coupling, and limited fan-out make a single change easy to reason about.",
      "source": "iso25010",
      "requirements": [
        {
          "id": "M-MOD-1",
          "source": "iso25010",
          "text": "Cyclomatic complexity MUST be \u226410 per function",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1121",
              "name": "Excessive McCabe Cyclomatic Complexity",
              "url": "https://cwe.mitre.org/data/definitions/1121.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Function cyclomatic complexity MUST be \u226410",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-MOD-2",
          "source": "iso25010",
          "text": "Each module MUST have a single clearly defined responsibility",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1080",
              "name": "Source Code File with Excessive Number of Lines of Code",
              "url": "https://cwe.mitre.org/data/definitions/1080.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Source files MUST NOT exceed language-appropriate line limits",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-MOD-3",
          "source": "iso25010",
          "text": "Package dependency cycles MUST be 0",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1047",
              "name": "Modules with Circular Dependencies",
              "url": "https://cwe.mitre.org/data/definitions/1047.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Module dependency graphs MUST be acyclic",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-MOD-4",
          "source": "iso25010",
          "text": "Functions MUST have \u22645 parameters; use an options object for more",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1064",
              "name": "Invokable Control Element with Signature Containing an Excessive Number of Parameters",
              "url": "https://cwe.mitre.org/data/definitions/1064.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Functions MUST have \u22645 parameters",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-MOD-6",
          "source": "iso25010",
          "text": "Functions MUST limit outward calls to \u22647 distinct callees to reduce coupling",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1048",
              "name": "Invokable Control Element with Large Number of Outward Calls",
              "url": "https://cwe.mitre.org/data/definitions/1048.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Functions MUST limit outward calls to \u22647 distinct callees to reduce coupling",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-MOD-7",
          "source": "iso25010",
          "text": "Inheritance depth MUST NOT exceed 4 levels",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1074",
              "name": "Class with Excessively Deep Inheritance",
              "url": "https://cwe.mitre.org/data/definitions/1074.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Inheritance depth MUST NOT exceed 4 levels",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-MOD-8",
          "source": "iso25010",
          "text": "Inheritance hierarchies MUST maintain consistent destructor/cleanup patterns",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1045",
              "name": "Parent Class with a Virtual Destructor and a Child Class without a Virtual Destructor",
              "url": "https://cwe.mitre.org/data/definitions/1045.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Inheritance hierarchies MUST maintain consistent destructor/cleanup patterns",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-MOD-9",
          "source": "iso25010",
          "text": "Components MUST call peers or immediate dependencies, not skip layers",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1054",
              "name": "Invocation of a Control Element at an Unnecessarily Deep Horizontal Layer",
              "url": "https://cwe.mitre.org/data/definitions/1054.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Components MUST call peers or immediate dependencies, not skip layers",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-MOD-10",
          "source": "iso25010",
          "text": "Trust boundaries MUST be enforced between components of different privilege levels",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1090",
              "name": "Method Containing Access of a Member Element from Another Class",
              "url": "https://cwe.mitre.org/data/definitions/1090.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Trust boundaries MUST be enforced between components of different privilege levels",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-MOD-11",
          "source": "iso25010",
          "text": "Class hierarchies MUST avoid excessive depth, circular dependencies, and improper virtual destructor patterns",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1042",
              "name": "Static Member Data Element outside of a Singleton Class Element",
              "url": "https://cwe.mitre.org/data/definitions/1042.html"
            },
            {
              "source": "cwe",
              "id": "1043",
              "name": "Data Element Aggregating an Excessively Large Number of Non-Primitive Elements",
              "url": "https://cwe.mitre.org/data/definitions/1043.html"
            },
            {
              "source": "cwe",
              "id": "1055",
              "name": "Multiple Inheritance from Concrete Classes",
              "url": "https://cwe.mitre.org/data/definitions/1055.html"
            },
            {
              "source": "cwe",
              "id": "1062",
              "name": "Parent Class with References to Child Class",
              "url": "https://cwe.mitre.org/data/definitions/1062.html"
            },
            {
              "source": "cwe",
              "id": "1079",
              "name": "Parent Class without Virtual Destructor Method",
              "url": "https://cwe.mitre.org/data/definitions/1079.html"
            },
            {
              "source": "cwe",
              "id": "1086",
              "name": "Class with Excessive Number of Child Classes",
              "url": "https://cwe.mitre.org/data/definitions/1086.html"
            },
            {
              "source": "cwe",
              "id": "1087",
              "name": "Class with Virtual Method without a Virtual Destructor",
              "url": "https://cwe.mitre.org/data/definitions/1087.html"
            }
          ]
        },
        {
          "id": "M-MOD-12",
          "source": "iso25010",
          "text": "Functions MUST NOT have variadic parameters without type safety or excessive file/data access operations",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1056",
              "name": "Invokable Control Element with Variadic Parameters",
              "url": "https://cwe.mitre.org/data/definitions/1056.html"
            },
            {
              "source": "cwe",
              "id": "1060",
              "name": "Excessive Number of Inefficient Server-Side Data Accesses",
              "url": "https://cwe.mitre.org/data/definitions/1060.html"
            },
            {
              "source": "cwe",
              "id": "1073",
              "name": "Non-SQL Invokable Control Element with Excessive Number of Data Resource Accesses",
              "url": "https://cwe.mitre.org/data/definitions/1073.html"
            },
            {
              "source": "cwe",
              "id": "1084",
              "name": "Invokable Control Element with Excessive File or Data Access Operations",
              "url": "https://cwe.mitre.org/data/definitions/1084.html"
            }
          ]
        },
        {
          "id": "M-MOD-13",
          "source": "iso25010",
          "text": "Code MUST maintain proper encapsulation and data element visibility",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "766",
              "name": "Critical Data Element Declared Public",
              "url": "https://cwe.mitre.org/data/definitions/766.html"
            },
            {
              "source": "cwe",
              "id": "1092",
              "name": "Use of Same Invokable Control Element in Multiple Architectural Layers",
              "url": "https://cwe.mitre.org/data/definitions/1092.html"
            }
          ]
        },
        {
          "id": "M-MOD-14",
          "source": "iso25010",
          "text": "Modules MUST NOT have hard-coded network configuration or platform-dependent components",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1051",
              "name": "Initialization with Hard-Coded Network Resource Configuration Data",
              "url": "https://cwe.mitre.org/data/definitions/1051.html"
            },
            {
              "source": "cwe",
              "id": "1100",
              "name": "Insufficient Isolation of System-Dependent Functions",
              "url": "https://cwe.mitre.org/data/definitions/1100.html"
            },
            {
              "source": "cwe",
              "id": "1102",
              "name": "Reliance on Machine-Dependent Data Representation",
              "url": "https://cwe.mitre.org/data/definitions/1102.html"
            },
            {
              "source": "cwe",
              "id": "1103",
              "name": "Use of Platform-Dependent Third Party Components",
              "url": "https://cwe.mitre.org/data/definitions/1103.html"
            },
            {
              "source": "cwe",
              "id": "1105",
              "name": "Insufficient Encapsulation of Machine-Dependent Functionality",
              "url": "https://cwe.mitre.org/data/definitions/1105.html"
            }
          ]
        }
      ]
    },
    {
      "name": "Reusability",
      "description": "Useful pieces can be lifted into other contexts without dragging unrelated code. Stable interfaces, no hidden global state, and clear inputs and outputs keep components portable.",
      "source": "iso25010",
      "requirements": [
        {
          "id": "M-REU-1",
          "source": "iso25010",
          "text": "Shared logic MUST be extracted into utility modules rather than duplicated",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1041",
              "name": "Use of Redundant Code",
              "url": "https://cwe.mitre.org/data/definitions/1041.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Duplicated logic MUST be extracted into shared functions",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-REU-2",
          "source": "iso25010",
          "text": "Public functions MUST NOT depend on global mutable state without an injectable override parameter or a documented reset mechanism for testing",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1057",
              "name": "Data Access Operations Outside of Expected Data Manager Component",
              "url": "https://cwe.mitre.org/data/definitions/1057.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Data access MUST be confined to the owning component",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-REU-3",
          "source": "iso25010",
          "text": "Interfaces MUST be preferred over concrete types in function signatures",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1061",
              "name": "Insufficient Encapsulation",
              "url": "https://cwe.mitre.org/data/definitions/1061.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Internal implementation details MUST be hidden behind public interfaces",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-REU-4",
          "source": "iso25010",
          "text": "Configuration MUST be injectable \u2014 functions that read environment variables MUST accept an override parameter (e.g., env dict) so callers can provide values without relying on process environment",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1188",
              "name": "Initialization of a Resource with an Insecure Default",
              "url": "https://cwe.mitre.org/data/definitions/1188.html"
            }
          ]
        },
        {
          "id": "M-REU-5",
          "source": "iso25010",
          "text": "Serialization control elements MUST be properly implemented",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1066",
              "name": "Missing Serialization Control Element",
              "url": "https://cwe.mitre.org/data/definitions/1066.html"
            },
            {
              "source": "cwe",
              "id": "1070",
              "name": "Serializable Data Element Containing non-Serializable Item Elements",
              "url": "https://cwe.mitre.org/data/definitions/1070.html"
            }
          ]
        },
        {
          "id": "M-REU-6",
          "source": "iso25010",
          "text": "Singleton classes MUST use proper locking and synchronization for instance creation",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1058",
              "name": "Invokable Control Element in Multi-Thread Context with non-Final Static Storable or Member Element",
              "url": "https://cwe.mitre.org/data/definitions/1058.html"
            },
            {
              "source": "cwe",
              "id": "1063",
              "name": "Creation of Class Instance within a Static Code Block",
              "url": "https://cwe.mitre.org/data/definitions/1063.html"
            },
            {
              "source": "cwe",
              "id": "1096",
              "name": "Singleton Class Instance Creation without Proper Locking or Synchronization",
              "url": "https://cwe.mitre.org/data/definitions/1096.html"
            }
          ]
        },
        {
          "id": "M-REU-7",
          "source": "iso25010",
          "text": "Data elements containing pointers MUST implement proper copy control",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1082",
              "name": "Class Instance Self Destruction Control Element",
              "url": "https://cwe.mitre.org/data/definitions/1082.html"
            },
            {
              "source": "cwe",
              "id": "1097",
              "name": "Persistent Storable Data Element without Associated Comparison Control Element",
              "url": "https://cwe.mitre.org/data/definitions/1097.html"
            },
            {
              "source": "cwe",
              "id": "1098",
              "name": "Data Element containing Pointer Item without Proper Copy Control Element",
              "url": "https://cwe.mitre.org/data/definitions/1098.html"
            }
          ]
        }
      ]
    },
    {
      "name": "Analyzability",
      "description": "A reader can understand what the code does and why. Naming, documentation, type annotations, and consistent structure shorten the time between opening a file and trusting it.",
      "source": "iso25010",
      "requirements": [
        {
          "id": "M-ANA-1",
          "source": "iso25010",
          "text": "Source files MUST NOT exceed 300 lines",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1080",
              "name": "Source Code File with Excessive Number of Lines of Code",
              "url": "https://cwe.mitre.org/data/definitions/1080.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Source files MUST NOT exceed language-appropriate line limits",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-ANA-2",
          "source": "iso25010",
          "text": "Functions MUST NOT exceed 50 lines",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1080",
              "name": "Source Code File with Excessive Number of Lines of Code",
              "url": "https://cwe.mitre.org/data/definitions/1080.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Source files MUST NOT exceed language-appropriate line limits",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-ANA-3",
          "source": "iso25010",
          "text": "Nesting depth MUST NOT exceed 4 levels",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1121",
              "name": "Excessive McCabe Cyclomatic Complexity",
              "url": "https://cwe.mitre.org/data/definitions/1121.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Function cyclomatic complexity MUST be \u226410",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-ANA-4",
          "source": "iso25010",
          "text": "Boolean expressions MUST NOT combine more than 3 conditions without extraction",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1121",
              "name": "Excessive McCabe Cyclomatic Complexity",
              "url": "https://cwe.mitre.org/data/definitions/1121.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Function cyclomatic complexity MUST be \u226410",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-ANA-5",
          "source": "iso25010",
          "text": "Public APIs MUST be documented with parameter and return descriptions",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1053",
              "name": "Missing Documentation for Design",
              "url": "https://cwe.mitre.org/data/definitions/1053.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Architectural decisions MUST be documented",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-ANA-6",
          "source": "iso25010",
          "text": "Control flow MUST NOT use unconditional jumps out of deeply nested blocks",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1075",
              "name": "Unconditional Control Flow Transfer outside of Switch Block",
              "url": "https://cwe.mitre.org/data/definitions/1075.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Control flow MUST NOT use unconditional jumps out of deeply nested blocks",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-ANA-7",
          "source": "iso25010",
          "text": "Loop counter variables MUST NOT be modified inside the loop body",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1095",
              "name": "Loop Condition Value Update within the Loop",
              "url": "https://cwe.mitre.org/data/definitions/1095.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Loop counter variables MUST NOT be modified inside the loop body",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "M-ANA-8",
          "source": "iso25010",
          "text": "Code complexity MUST remain within measurable thresholds (Halstead, nesting depth, attack surface)",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1120",
              "name": "Excessive Code Complexity",
              "url": "https://cwe.mitre.org/data/definitions/1120.html"
            },
            {
              "source": "cwe",
              "id": "1122",
              "name": "Excessive Halstead Complexity",
              "url": "https://cwe.mitre.org/data/definitions/1122.html"
            },
            {
              "source": "cwe",
              "id": "1124",
              "name": "Excessively Deep Nesting",
              "url": "https://cwe.mitre.org/data/definitions/1124.html"
            },
            {
              "source": "cwe",
              "id": "1125",
              "name": "Excessive Attack Surface",
              "url": "https://cwe.mitre.org/data/definitions/1125.html"
            }
          ]
        },
        {
          "id": "M-ANA-9",
          "source": "iso25010",
          "text": "Source code MUST follow consistent naming, formatting, and style conventions",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "710",
              "name": "Improper Adherence to Coding Standards",
              "url": "https://cwe.mitre.org/data/definitions/710.html"
            },
            {
              "source": "cwe",
              "id": "1076",
              "name": "Insufficient Adherence to Expected Conventions",
              "url": "https://cwe.mitre.org/data/definitions/1076.html"
            },
            {
              "source": "cwe",
              "id": "1078",
              "name": "Inappropriate Source Code Style or Formatting",
              "url": "https://cwe.mitre.org/data/definitions/1078.html"
            },
            {
              "source": "cwe",
              "id": "1099",
              "name": "Inconsistent Naming Conventions for Identifiers",
              "url": "https://cwe.mitre.org/data/definitions/1099.html"
            },
            {
              "source": "cwe",
              "id": "1113",
              "name": "Inappropriate Comment Style",
              "url": "https://cwe.mitre.org/data/definitions/1113.html"
            },
            {
              "source": "cwe",
              "id": "1114",
              "name": "Inappropriate Whitespace Style",
              "url": "https://cwe.mitre.org/data/definitions/1114.html"
            },
            {
              "source": "cwe",
              "id": "1115",
              "name": "Source Code Element without Standard Prologue",
              "url": "https://cwe.mitre.org/data/definitions/1115.html"
            }
          ]
        },
        {
          "id": "M-ANA-10",
          "source": "iso25010",
          "text": "Code MUST NOT contain dead code, empty blocks, irrelevant code, or redundant expressions",
          "severity": null,
          "scope": null,
          "refs": [
            {

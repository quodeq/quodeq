{
  "id": "reliability",
  "name": "Reliability",
  "description": "How dependably the system performs its required functions over time. Maturity, fault tolerance, and recoverability keep failures rare, contained, and easy to bounce back from when they happen.",
  "sources": [
    "iso25010",
    "cisq",
    "cert"
  ],
  "principles": [
    {
      "name": "Maturity",
      "description": "How rarely the system fails under normal use. Higher maturity comes from tests, type checks, and disciplined error handling on every path so defects do not reach production.",
      "source": "iso25010",
      "requirements": [
        {
          "id": "R-MAT-1",
          "source": "iso25010",
          "text": "All public functions MUST have corresponding test files",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1173",
              "name": "Improper Use of Validation Framework",
              "url": "https://cwe.mitre.org/data/definitions/1173.html"
            }
          ]
        },
        {
          "id": "R-MAT-2",
          "source": "iso25010",
          "text": "Edge cases (empty input, boundary values) MUST be tested explicitly",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "754",
              "name": "Improper Check for Unusual or Exceptional Conditions",
              "url": "https://cwe.mitre.org/data/definitions/754.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Boundary and edge-case conditions MUST be checked explicitly",
              "url": "https://www.it-cisq.org/coding-rules/"
            },
            {
              "source": "cert",
              "id": "ERR05-J",
              "name": "Do not let checked exceptions escape from a finally block",
              "url": "https://wiki.sei.cmu.edu/confluence/display/java/ERR05-J.+Do+not+let+checked+exceptions+escape+from+a+finally+block"
            }
          ]
        },
        {
          "id": "R-MAT-3",
          "source": "iso25010",
          "text": "Error paths MUST be tested, not only happy paths",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "390",
              "name": "Detection of Error Condition Without Action",
              "url": "https://cwe.mitre.org/data/definitions/390.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "All detected error conditions MUST trigger handling logic",
              "url": "https://www.it-cisq.org/coding-rules/"
            },
            {
              "source": "cert",
              "id": "ERR00-J",
              "name": "Do not suppress or ignore checked exceptions",
              "url": "https://wiki.sei.cmu.edu/confluence/display/java/ERR00-J.+Do+not+suppress+or+ignore+checked+exceptions"
            }
          ]
        },
        {
          "id": "R-MAT-4",
          "source": "iso25010",
          "text": "Deprecated APIs MUST NOT be used; use supported alternatives",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "477",
              "name": "Use of Obsolete Function",
              "url": "https://cwe.mitre.org/data/definitions/477.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Deprecated functions MUST be replaced with supported alternatives",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "R-MAT-5",
          "source": "iso25010",
          "text": "Type annotations MUST be used on public function signatures",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1076",
              "name": "Insufficient Adherence to Expected Conventions",
              "url": "https://cwe.mitre.org/data/definitions/1076.html"
            }
          ]
        },
        {
          "id": "R-MAT-6",
          "source": "iso25010",
          "text": "Resources MUST be properly initialized before use",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "456",
              "name": "Missing Initialization of a Variable",
              "url": "https://cwe.mitre.org/data/definitions/456.html"
            },
            {
              "source": "cwe",
              "id": "665",
              "name": "Improper Initialization",
              "url": "https://cwe.mitre.org/data/definitions/665.html"
            },
            {
              "source": "cwe",
              "id": "908",
              "name": "Use of Uninitialized Resource",
              "url": "https://cwe.mitre.org/data/definitions/908.html"
            }
          ]
        },
        {
          "id": "R-MAT-7",
          "source": "iso25010",
          "text": "Concurrent access to shared resources MUST be properly synchronized",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "362",
              "name": "Concurrent Execution using Shared Resource with Improper Synchronization ('Race Condition')",
              "url": "https://cwe.mitre.org/data/definitions/362.html"
            },
            {
              "source": "cwe",
              "id": "662",
              "name": "Improper Synchronization",
              "url": "https://cwe.mitre.org/data/definitions/662.html"
            },
            {
              "source": "cwe",
              "id": "764",
              "name": "Multiple Locks of a Critical Resource",
              "url": "https://cwe.mitre.org/data/definitions/764.html"
            },
            {
              "source": "cwe",
              "id": "820",
              "name": "Missing Synchronization",
              "url": "https://cwe.mitre.org/data/definitions/820.html"
            },
            {
              "source": "cwe",
              "id": "821",
              "name": "Incorrect Synchronization",
              "url": "https://cwe.mitre.org/data/definitions/821.html"
            },
            {
              "source": "cwe",
              "id": "833",
              "name": "Deadlock",
              "url": "https://cwe.mitre.org/data/definitions/833.html"
            },
            {
              "source": "cert",
              "id": "THI02-J",
              "name": "Notify all waiting threads rather than a single thread",
              "url": "https://wiki.sei.cmu.edu/confluence/display/java/THI02-J.+Notify+all+waiting+threads+rather+than+a+single+thread"
            },
            {
              "source": "cert",
              "id": "CON35-C",
              "name": "Avoid deadlock by locking in a predefined order",
              "url": "https://wiki.sei.cmu.edu/confluence/pages/viewpage.action?pageId=87152261"
            },
            {
              "source": "cert",
              "id": "LCK07-J",
              "name": "Avoid deadlock by requesting and releasing locks in the same order",
              "url": "https://wiki.sei.cmu.edu/confluence/display/java/LCK07-J.+Avoid+deadlock+by+requesting+and+releasing+locks+in+the+same+order"
            },
            {
              "source": "cert",
              "id": "LCK08-J",
              "name": "Ensure actively held locks are released on exceptional conditions",
              "url": "https://wiki.sei.cmu.edu/confluence/display/java/LCK08-J.+Ensure+actively+held+locks+are+released+on+exceptional+conditions"
            },
            {
              "source": "cert",
              "id": "THI03-J",
              "name": "Always invoke wait() and await() methods inside a loop",
              "url": "https://wiki.sei.cmu.edu/confluence/display/java/THI03-J.+Always+invoke+wait%28%29+and+await%28%29+methods+inside+a+loop"
            },
            {
              "source": "cert",
              "id": "CON36-C",
              "name": "Wrap functions that can spuriously wake up in a loop",
              "url": "https://wiki.sei.cmu.edu/confluence/display/c/CON36-C.+Wrap+functions+that+can+spuriously+wake+up+in+a+loop"
            }
          ]
        },
        {
          "id": "R-MAT-8",
          "source": "iso25010",
          "text": "Calculations and comparisons MUST be correct and avoid undefined behavior",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "682",
              "name": "Incorrect Calculation",
              "url": "https://cwe.mitre.org/data/definitions/682.html"
            },
            {
              "source": "cwe",
              "id": "758",
              "name": "Reliance on Undefined, Unspecified, or Implementation-Defined Behavior",
              "url": "https://cwe.mitre.org/data/definitions/758.html"
            }
          ]
        }
      ]
    },
    {
      "name": "Availability",
      "description": "How often the system is operational and reachable when users need it. Availability suffers when single points of failure, slow startups, or unbounded resources take the system offline.",
      "source": "iso25010",
      "requirements": [
        {
          "id": "R-AVL-1",
          "source": "iso25010",
          "text": "Health-check endpoints MUST be implemented for long-running services",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1059",
              "name": "Insufficient Technical Documentation",
              "url": "https://cwe.mitre.org/data/definitions/1059.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Error handling behaviour MUST be documented for public APIs",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "R-AVL-2",
          "source": "iso25010",
          "text": "Circuit breakers MUST be used for external service calls",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "400",
              "name": "Uncontrolled Resource Consumption",
              "url": "https://cwe.mitre.org/data/definitions/400.html"
            }
          ]
        },
        {
          "id": "R-AVL-3",
          "source": "iso25010",
          "text": "Retry logic MUST use exponential backoff with jitter",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "400",
              "name": "Uncontrolled Resource Consumption",
              "url": "https://cwe.mitre.org/data/definitions/400.html"
            }
          ]
        },
        {
          "id": "R-AVL-4",
          "source": "iso25010",
          "text": "Timeouts MUST be set on all external HTTP and database calls",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1088",
              "name": "Synchronous Access of Remote Resource without Timeout",
              "url": "https://cwe.mitre.org/data/definitions/1088.html"
            }
          ]
        },
        {
          "id": "R-AVL-5",
          "source": "iso25010",
          "text": "Graceful shutdown handlers MUST be implemented for server processes",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "404",
              "name": "Improper Resource Shutdown or Release",
              "url": "https://cwe.mitre.org/data/definitions/404.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Resources MUST be shut down in the correct order during cleanup",
              "url": "https://www.it-cisq.org/coding-rules/"
            },
            {
              "source": "cert",
              "id": "FIO42-C",
              "name": "Close files when they are no longer needed",
              "url": "https://wiki.sei.cmu.edu/confluence/display/c/FIO42-C.+Close+files+when+they+are+no+longer+needed"
            },
            {
              "source": "cert",
              "id": "MEM31-C",
              "name": "Free dynamically allocated memory when no longer needed",
              "url": "https://wiki.sei.cmu.edu/confluence/display/c/MEM31-C.+Free+dynamically+allocated+memory+when+no+longer+needed"
            }
          ]
        }
      ]
    },
    {
      "name": "Fault Tolerance",
      "description": "How well the system keeps working when something goes wrong. Errors are isolated, retries and timeouts are explicit, and a misbehaving dependency does not bring everything down.",
      "source": "iso25010",
      "requirements": [
        {
          "id": "R-FT-1",
          "source": "iso25010",
          "text": "Exceptions MUST be caught and handled; empty catch blocks are forbidden",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "390",
              "name": "Detection of Error Condition Without Action",
              "url": "https://cwe.mitre.org/data/definitions/390.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "All detected error conditions MUST trigger handling logic",
              "url": "https://www.it-cisq.org/coding-rules/"
            },
            {
              "source": "cert",
              "id": "ERR00-J",
              "name": "Do not suppress or ignore checked exceptions",
              "url": "https://wiki.sei.cmu.edu/confluence/display/java/ERR00-J.+Do+not+suppress+or+ignore+checked+exceptions"
            }
          ]
        },
        {
          "id": "R-FT-2",
          "source": "iso25010",
          "text": "Null/undefined dereferences MUST be guarded before use",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "476",
              "name": "NULL Pointer Dereference",
              "url": "https://cwe.mitre.org/data/definitions/476.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Nullable references MUST be checked before dereferencing",
              "url": "https://www.it-cisq.org/coding-rules/"
            },
            {
              "source": "cert",
              "id": "ERR08-J",
              "name": "Do not catch NullPointerException or any of its ancestors",
              "url": "https://wiki.sei.cmu.edu/confluence/display/java/ERR08-J.+Do+not+catch+NullPointerException+or+any+of+its+ancestors"
            }
          ]
        },
        {
          "id": "R-FT-3",
          "source": "iso25010",
          "text": "Async operations MUST handle rejection/error paths explicitly",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "755",
              "name": "Improper Handling of Exceptional Conditions",
              "url": "https://cwe.mitre.org/data/definitions/755.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Exceptional conditions MUST be caught and handled appropriately",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "R-FT-4",
          "source": "iso25010",
          "text": "Input from external sources MUST be validated before processing",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "20",
              "name": "Improper Input Validation",
              "url": "https://cwe.mitre.org/data/definitions/20.html"
            }
          ]
        },
        {
          "id": "R-FT-5",
          "source": "iso25010",
          "text": "Fallback values MUST be provided for optional configuration",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "1188",
              "name": "Initialization of a Resource with an Insecure Default",
              "url": "https://cwe.mitre.org/data/definitions/1188.html"
            }
          ]
        },
        {
          "id": "R-FT-6",
          "source": "iso25010",
          "text": "Return values from fallible operations MUST be checked",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "252",
              "name": "Unchecked Return Value",
              "url": "https://cwe.mitre.org/data/definitions/252.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Return values from fallible operations MUST be checked",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "R-FT-7",
          "source": "iso25010",
          "text": "Catch blocks MUST target specific exception types, not generic Exception",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "396",
              "name": "Declaration of Catch for Generic Exception",
              "url": "https://cwe.mitre.org/data/definitions/396.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Catch blocks MUST target specific exception types, not generic Exception",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "R-FT-8",
          "source": "iso25010",
          "text": "Throw declarations MUST specify concrete exception types",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "397",
              "name": "Declaration of Throws for Generic Exception",
              "url": "https://cwe.mitre.org/data/definitions/397.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Throw declarations MUST specify concrete exception types",
              "url": "https://www.it-cisq.org/coding-rules/"
            },
            {
              "source": "cert",
              "id": "ERR07-J",
              "name": "Do not throw RuntimeException, Exception, or Throwable",
              "url": "https://wiki.sei.cmu.edu/confluence/display/java/ERR07-J.+Do+not+throw+RuntimeException%2C+Exception%2C+or+Throwable"
            }
          ]
        },
        {
          "id": "R-FT-9",
          "source": "iso25010",
          "text": "Boundary and edge-case conditions MUST be checked explicitly",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "754",
              "name": "Improper Check for Unusual or Exceptional Conditions",
              "url": "https://cwe.mitre.org/data/definitions/754.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Boundary and edge-case conditions MUST be checked explicitly",
              "url": "https://www.it-cisq.org/coding-rules/"
            },
            {
              "source": "cert",
              "id": "ERR05-J",
              "name": "Do not let checked exceptions escape from a finally block",
              "url": "https://wiki.sei.cmu.edu/confluence/display/java/ERR05-J.+Do+not+let+checked+exceptions+escape+from+a+finally+block"
            }
          ]
        },
        {
          "id": "R-FT-10",
          "source": "iso25010",
          "text": "Control flow MUST be structured and predictable; no unreachable statements",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "691",
              "name": "Insufficient Control Flow Management",
              "url": "https://cwe.mitre.org/data/definitions/691.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Control flow MUST be structured and predictable; no unreachable statements",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "R-FT-11",
          "source": "iso25010",
          "text": "Recursive functions MUST have verifiable termination conditions",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "674",
              "name": "Uncontrolled Recursion",
              "url": "https://cwe.mitre.org/data/definitions/674.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "Recursive functions MUST have verifiable termination conditions",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "R-FT-12",
          "source": "iso25010",
          "text": "All loops MUST have reachable termination conditions",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "835",
              "name": "Loop with Unreachable Exit Condition ('Infinite Loop')",
              "url": "https://cwe.mitre.org/data/definitions/835.html"
            },
            {
              "source": "cisq",
              "id": null,
              "name": "All loops MUST have reachable termination conditions",
              "url": "https://www.it-cisq.org/coding-rules/"
            }
          ]
        },
        {
          "id": "R-FT-13",
          "source": "iso25010",
          "text": "Temporary files MUST be created using secure APIs (mktemp) to prevent race conditions",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "377",
              "name": "Insecure Temporary File",
              "url": "https://cwe.mitre.org/data/definitions/377.html"
            }
          ]
        },
        {
          "id": "R-FT-14",
          "source": "iso25010",
          "text": "Error conditions MUST be detected and handled, not silently ignored",
          "severity": null,
          "scope": null,
          "refs": [
            {
              "source": "cwe",
              "id": "248",
              "name": "Uncaught Exception",
              "url": "https://cwe.mitre.org/data/definitions/248.html"
            },
            {
              "source": "cwe",
              "id": "274",
              "name": "Improper Handling of Insufficient Privileges",
              "url": "https://cwe.mitre.org/data/definitions/274.html"
            },
            {
              "source": "cwe",
              "id": "280",
              "name": "Improper Handling of Insufficient Permissions or Privileges ",
              "url": "https://cwe.mitre.org/data/definitions/280.html"
            },
            {
              "source": "cwe",
              "id": "369",
              "name": "Divide By Zero",
              "url": "https://cwe.mitre.org/data/definitions/369.html"
            },
            {
              "source": "cwe",
              "id": "391",
              "name": "Unchecked Error Condition",
              "url": "https://cwe.mitre.org/data/definitions/391.html"
            },
            {
              "source": "cwe",
              "id": "394",
              "name": "Unexpected Status Code or Return Value",
              "url": "https://cwe.mitre.org/data/definitions/394.html"
            },
            {
              "source": "cwe",
              "id": "460",
              "name": "Improper Cleanup on Thrown Exception",
              "url": "https://cwe.mitre.org/data/definitions/460.html"
            },
            {
              "source": "cwe",
              "id": "544",
              "name": "Missing Standardized Error Handling Mechanism",
              "url": "https://cwe.mitre.org/data/definitions/544.html"
            },
            {
              "source": "cwe",
              "id": "550",
              "name": "Server-generated Error Message Containing Sensitive Information",
              "url": "https://cwe.mitre.org/data/definitions/550.html"
            },
            {
              "source": "cwe",
              "id": "636",
              "name": "Not Failing Securely ('Failing Open')",
              "url": "https://cwe.mitre.org/data/definitions/636.html"
            },
            {
              "source": "cwe",
              "id": "676",
              "name": "Use of Potentially Dangerous Function",
              "url": "https://cwe.mitre.org/data/definitions/676.html"
            },
            {
              "source": "cwe",
              "id": "703",
              "name": "Improper Check or Handling of Exceptional Conditions",
              "url": "https://cwe.mitre.org/data/definitions/703.html"
            },
            {
              "source": "cert",
              "id": "ERR05-J",
              "name": "Do not let checked exceptions escape from a finally block",
              "url": "https://wiki.sei.cmu.edu/confluence/display/java/ERR05-J.+Do+not+let+checked+exceptions+escape+from+a+finally+block"
            },
            {
              "source": "cert",
              "id": "ERR00-C",
              "name": "Adopt and implement a consistent and comprehensive error-handling policy",
              "url": "https://wiki.sei.cmu.edu/confluence/display/c/ERR00-C.+Adopt+and+implement+a+consistent+and+comprehensive+error-handling+policy"

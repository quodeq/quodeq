{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "summary", "principle_practice_map", "requirements_coverage"],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "discipline", "principle_count", "practice_count", "sources"],
      "properties": {
        "dimension": {"type": "string"},
        "discipline": {"type": "string"},
        "principle_count": {"type": "integer"},
        "practice_count": {"type": "integer"},
        "sources": {"type": "array", "items": {"type": "string"}},
        "requirements_total": {"type": "integer"},
        "requirements_covered": {"type": "integer"},
        "coverage": {"type": "string"},
        "generated": {"type": "string"},
        "mapper_version": {"type": "string"}
      }
    },
    "summary": {"type": "string"},
    "principle_practice_map": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["principle", "weight", "practices", "covers"],
        "properties": {
          "principle": {"type": "string"},
          "weight": {"type": "string"},
          "practices": {"type": "string"},
          "covers": {"type": "string"}
        }
      }
    },
    "requirements_coverage": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "status", "covered_by"],
        "properties": {
          "id": {"type": "string"},
          "text": {"type": "string"},
          "status": {"type": "string"},
          "covered_by": {"type": "string"}
        }
      }
    },
    "coverage_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "impact", "recommendation"],
        "properties": {
          "id": {"type": "string"},
          "text": {"type": "string"},
          "impact": {"type": "string"},
          "recommendation": {"type": "string"}
        }
      }
    },
    "excluded_principles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "reason"],
        "properties": {
          "name": {"type": "string"},
          "reason": {"type": "string"}
        }
      }
    },
    "principles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "weight",
          "weight_justification",
          "practice_count",
          "covers",
          "definition",
          "violated_when",
          "implementing_practices",
          "scoring_rubric"
        ],
        "properties": {
          "name": {"type": "string"},
          "weight": {"type": "string"},
          "weight_justification": {"type": "string"},
          "practice_count": {"type": "integer"},
          "covers": {"type": "array", "items": {"type": "string"}},
          "definition": {"type": "string"},
          "violated_when": {"type": "array", "items": {"type": "string"}},
          "implementing_practices": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "name", "relevance"],
              "properties": {
                "id": {"type": "string"},
                "name": {"type": "string"},
                "relevance": {"type": "string"}
              }
            }
          },
          "scoring_rubric": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["range", "criteria"],
              "properties": {
                "range": {"type": "string"},
                "criteria": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "scoring_formula": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formula", "weights", "total_points", "grade_interpretation"],
      "properties": {
        "formula": {"type": "string"},
        "weights": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["level", "principles", "points"],
            "properties": {
              "level": {"type": "string"},
              "principles": {"type": "array", "items": {"type": "string"}},
              "points": {"type": "integer"}
            }
          }
        },
        "total_points": {"type": "integer"},
        "grade_interpretation": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["range", "grade", "meaning"],
            "properties": {
              "range": {"type": "string"},
              "grade": {"type": "string"},
              "meaning": {"type": "string"}
            }
          }
        }
      }
    }
  }
}

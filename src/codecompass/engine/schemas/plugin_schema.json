{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plugin manifest",
  "type": "object",
  "required": ["id", "name", "version", "engine_version", "detects"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "engine_version": { "type": "string" },
    "detects": {
      "type": "object",
      "required": ["extensions"],
      "properties": {
        "extensions": {
          "type": "array",
          "items": { "type": "string", "pattern": "^\\." },
          "minItems": 1
        },
        "config_files": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "cross_cutting": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
